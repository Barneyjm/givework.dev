# Postgres connection string. A Neon URL in practice; a local Postgres for tests.
DATABASE_URL=postgres://postgres:postgres@localhost:5433/givework

# Secret used to sign/verify JWTs (HS256). Required by the server, the MCP
# server, and the mint-token script. Use a long random value in production.
JWT_SECRET=change-me

# Optional: HTTP port for the server (default 3000).
# PORT=3000

# Intake decomposer. Default is a deterministic stub (no model, used by tests).
# Set 'local' to use a free local LLM via an OpenAI-compatible endpoint (Ollama,
# LM Studio, llama.cpp). Falls back to the stub if the endpoint is unreachable.
# DECOMPOSER=local
# DECOMPOSER_BASE_URL=http://localhost:11434/v1
# DECOMPOSER_MODEL=glm-4.7-flash:latest

# Runner: the dev JWT the runner acts as (mint with `npm run mint-token -- --dev <id>`).
# GIVEWORK_TOKEN=

# Runner transport. Set GIVEWORK_API_URL to the deployed platform to run as a
# real volunteer over HTTP — needs only this URL + GIVEWORK_TOKEN, no DB access.
# When unset, the runner falls back to the local MCP/stdio server (needs DATABASE_URL).
# GIVEWORK_API_URL=https://givework.<subdomain>.workers.dev

# Runner task executor. Default is a deterministic stub (no inference, used by tests).
#   claude     → run tasks via the `claude -p` CLI on your Claude subscriber credit (production; no API key)
#   claude-api → reference Anthropic SDK impl (needs ANTHROPIC_API_KEY; not the ship path)
# EXECUTOR=claude
