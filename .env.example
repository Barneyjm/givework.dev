# Postgres connection string. A Neon URL in practice; a local Postgres for tests.
DATABASE_URL=postgres://postgres:postgres@localhost:5433/givework

# Secret used to sign/verify JWTs (HS256). Required by the server, the MCP
# server, and the mint-token script. Use a long random value in production.
JWT_SECRET=change-me

# Optional: HTTP port for the server (default 3000).
# PORT=3000

# MCP server only: the dev JWT the runner acts as (mint with `npm run mint-token -- --dev <id>`).
# GIVEWORK_TOKEN=
