{
  "name": "givework",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Givework Stage 1 — budget ledger core",
  "scripts": {
    "migrate": "node --env-file-if-exists=.env --import tsx scripts/migrate.ts",
    "seed": "node --env-file-if-exists=.env --import tsx scripts/seed-demo.ts",
    "dev": "node --env-file-if-exists=.env --import tsx src/server.ts",
    "start": "node --env-file-if-exists=.env --import tsx src/server.ts",
    "mcp": "node --env-file-if-exists=.env --import tsx src/mcp.ts",
    "runner": "node --env-file-if-exists=.env --import tsx src/runner.ts",
    "mint-token": "node --env-file-if-exists=.env --import tsx scripts/mint-token.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "cf:dev": "wrangler dev",
    "deploy": "wrangler deploy"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@hono/node-server": "^1.13.7",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "hono": "^4.6.14",
    "jose": "^6.2.3",
    "pg": "^8.13.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "wrangler": "^4.40.0"
  }
}
